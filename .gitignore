# =============================================================================
# .gitignore — banking-stream-enrichment
# =============================================================================

# ---------------------------------------------------------------------------
# Môi trường & credentials — KHÔNG BAO GIỜ commit
# ---------------------------------------------------------------------------
.env
secrets/
*.pem
*.key
*.p12
service-account*.json

# ---------------------------------------------------------------------------
# Data files — lớn, tái tạo được từ script
# Giữ lại: data/raw/.gitkeep, data/output/.gitkeep (cấu trúc thư mục)
# ---------------------------------------------------------------------------
data/raw/*
data/output/*
!data/raw/.gitkeep
!data/output/.gitkeep

# ---------------------------------------------------------------------------
# Airflow runtime — sinh ra tự động khi chạy
# Giữ lại: .gitkeep để thư mục tồn tại trong repo
# ---------------------------------------------------------------------------
airflow/logs/*
!airflow/logs/.gitkeep
airflow/plugins/__pycache__/

# ---------------------------------------------------------------------------
# dbt runtime
# ---------------------------------------------------------------------------
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/profiles.yml

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.coverage
htmlcov/

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.log
docker-compose.yaml
