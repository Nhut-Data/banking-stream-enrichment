# =============================================================================
# .env.example — Banking Stream-Table Join Enrichment Platform
#
# CÁCH DÙNG:
#   cp .env.example .env
#   Sau đó chỉnh các giá trị có comment "THAY ĐỔI TRƯỚC KHI CHẠY"
#
# KHÔNG commit file .env thật vào git (.gitignore đã loại trừ rồi)
# =============================================================================


# =============================================================================
# AIRFLOW
# =============================================================================

# THAY ĐỔI TRƯỚC KHI CHẠY: generate bằng lệnh:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_WITH_GENERATED_KEY

# Airflow Web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# JWT auth (dùng cho Airflow 3.x API)
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret_change_me
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# UID của user chạy Airflow trong container (Linux: chạy "id -u" để lấy)
# Mặc định 50000 nếu không set — chỉ cần đổi nếu gặp permission issues
AIRFLOW_UID=50000

# Pip packages bổ sung khi container start (dùng cho quick test, không dùng production)
# Để trống vì đã cài sẵn trong Dockerfile
_PIP_ADDITIONAL_REQUIREMENTS=

# Path đến file env (dùng trong docker-compose.yml)
ENV_FILE_PATH=.env


# =============================================================================
# POSTGRESQL
# =============================================================================

# Credentials dùng cho cả Airflow metadata DB và Berka data DB
# THAY ĐỔI TRƯỚC KHI CHẠY trong môi trường thật
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow

# Database names — thường không cần đổi
AIRFLOW_DB=airflow
BERKA_DB=berka


# =============================================================================
# DEBEZIUM / REPLICATION USER
# =============================================================================

# Credentials của user replicator tạo trong 001_create_berka_schema.sql
# Debezium dùng user này để kết nối Postgres và đọc WAL
# THAY ĐỔI TRƯỚC KHI CHẠY — phải khớp với password trong SQL init script
REPLICATOR_USER=replicator
REPLICATOR_PASSWORD=replicator_password


# =============================================================================
# KAFKA
# =============================================================================

# Internal: dùng trong docker network (Debezium, producer, consumer)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# External: dùng từ host machine (test local, debug)
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:9094

# Topic names — khớp với kafka-init trong docker-compose.yml
KAFKA_TOPIC_TRANS=cdc.public.trans
KAFKA_TOPIC_CLIENT=cdc.public.client
KAFKA_TOPIC_DISPOSITION=cdc.public.disposition
KAFKA_TOPIC_ACCOUNT=cdc.public.account
KAFKA_TOPIC_DISTRICT=cdc.public.district
KAFKA_TOPIC_ENRICHED=transactions.events
KAFKA_TOPIC_DLQ=transactions.dlq


# =============================================================================
# DATA GENERATION (data_generation/)
# =============================================================================

# RANDOM_SEED cố định để đảm bảo reproducibility:
# cùng seed + cùng input → cùng output, ai clone repo cũng ra kết quả y hệt
RANDOM_SEED=42

# Kích thước dataset sinh ra
DEV_SIZE=100000
LOADTEST_SIZE=1000000

# Tỷ lệ lỗi tiêm (2-5% đã chốt trong context)
CORRUPTION_RATE_DUPLICATE=0.02
CORRUPTION_RATE_REFERENTIAL=0.02
CORRUPTION_RATE_MISSING=0.03

# Paths
DATA_RAW_DIR=data/raw
DATA_OUTPUT_DIR=data/output
CORRUPTION_MANIFEST_PATH=docs/corruption_manifest.json


# =============================================================================
# GOOGLE CLOUD PLATFORM (chỉ cần khi deploy cloud — load test 1 lần)
# =============================================================================

# THAY ĐỔI khi chạy cloud deployment
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=banking_enrichment
BQ_LOCATION=US

# Path đến service account key file
# Trong docker-compose.yml, thư mục ~/.config/gcloud được mount vào container
GOOGLE_APPLICATION_CREDENTIALS=/home/airflow/.config/gcloud/application_default_credentials.json
